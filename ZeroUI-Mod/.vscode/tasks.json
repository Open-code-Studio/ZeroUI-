{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle build",
            "type": "shell",
            "command": "/tmp/gradle-8.10/bin/gradle",
            "args": ["build", "--no-daemon"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "JAVA_HOME": "/Users/cangcang/Documents/jdk21"
                }
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "gradle clean",
            "type": "shell",
            "command": "/tmp/gradle-8.10/bin/gradle",
            "args": ["clean", "--no-daemon"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "JAVA_HOME": "/Users/cangcang/Documents/jdk21"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "copy to mods",
            "type": "shell",
            "command": "cp",
            "args": [
                "${workspaceFolder}/build/libs/zeroui-1.0.0.jar",
                "${env:HOME}/Library/Application Support/minecraft/versions/1.21.11/mods/"
            ],
            "dependsOn": ["gradle build"],
            "problemMatcher": []
        }
    ]
}
